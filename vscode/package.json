{
    "name": "hulk-vscode",
    "displayName": "HULK Programming Language",
    "description": "Syntax highlighting and support for the HULK programming language.",
    "version": "0.6.1",
    "publisher": "apiad",
    "author": "Alejandro Piad Morffis <apiad@apiad.net>",
    "engines": {
        "vscode": "^1.80.0"
    },
    "icon": "images/hulk.png",
    "repository": {
        "type": "git",
        "url": "https://github.com/matcom/hulk.git"
    },
    "homepage": "https://github.com/matcom/hulk",
    "bugs": {
        "url": "https://github.com/matcom/hulk/issues"
    },
    "categories": [
        "Programming Languages"
    ],
    "contributes": {
        "languages": [
            {
                "id": "hulk",
                "aliases": [
                    "HULK",
                    "hulk"
                ],
                "extensions": [
                    ".hulk"
                ],
                "configuration": "./language-configuration.json",
                "icon": {
                    "light": "images/hulk.png",
                    "dark": "images/hulk.png"
                }
            }
        ],
        "grammars": [
            {
                "language": "hulk",
                "scopeName": "source.hulk",
                "path": "./syntaxes/hulk.tmLanguage.json"
            },
            {
                "scopeName": "markdown.hulk.codeblock",
                "path": "./syntaxes/hulk-markdown.tmLanguage.json",
                "injectTo": [
                    "text.html.markdown",
                    "text.quarto",
                    "source.quarto",
                    "source.qmd",
                    "source.markdown",
                    "text.markdown",
                    "text.html.quarto",
                    "markup.fenced_code.block.quarto"
                ]
            }
        ],

        "snippets": [
            {
                "language": "hulk",
                "path": "./snippets/hulk.code-snippets"
            }
        ]
    }
}
